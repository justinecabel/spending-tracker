{
  "name": "@spending-tracker/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts --format esm --target node22 && node scripts/fix-node-sqlite.mjs",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "db:init": "tsx src/db/seed.ts",
    "test": "node --import tsx --test test/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@spending-tracker/shared": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "google-auth-library": "^9.14.1",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.0.8",
    "ws": "^8.18.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^24.0.15",
    "@types/ws": "^8.18.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.1",
    "typescript": "^5.9.2"
  }
}
